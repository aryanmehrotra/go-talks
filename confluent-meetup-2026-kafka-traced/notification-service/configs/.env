APP_NAME=notification-service
HTTP_PORT=8002
METRICS_PORT=2123

LOG_LEVEL=INFO

PUBSUB_BACKEND=KAFKA
PUBSUB_BROKER=kafka:9094
CONSUMER_ID=notification-service

# Default: GoFr's hosted tracer — view at https://tracer.gofr.dev
#TRACE_EXPORTER=gofr
TRACER_RATIO=1.0

# Local: Jaeger via OTLP (UI at localhost:11686)
TRACE_EXPORTER=otlp
TRACER_URL=jaeger:4317
