APP_NAME=api-gateway
HTTP_PORT=8000
METRICS_PORT=2121

LOG_LEVEL=INFO

PUBSUB_BACKEND=KAFKA
PUBSUB_BROKER=kafka:9094
CONSUMER_ID=api-gateway

# Default: GoFr's hosted tracer — view at https://tracer.gofr.dev
# No TRACER_URL needed; defaults to https://tracer-api.gofr.dev/api/spans
#TRACE_EXPORTER=gofr
TRACER_RATIO=1.0

# Local: Jaeger via OTLP (UI at localhost:11686)
TRACE_EXPORTER=otlp
TRACER_URL=jaeger:4317
